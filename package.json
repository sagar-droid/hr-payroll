{
  "name": "hr-payroll",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "prepare": "[ -n \"$CI\" ] || husky || true"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3"
  }
}
